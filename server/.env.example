# Supabase project settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co

# Use the "service_role" key here. It stays on the server only and bypasses
# Row Level Security so the API can read/write on behalf of the demo user.
# NEVER expose this key in the frontend.
SUPABASE_SERVICE_KEY=your-service-role-key

# Port the Express server listens on (Render sets this automatically)
PORT=4000

# Allowed frontend origin for CORS. In production set this to your Vercel URL,
# e.g. https://wealthpilot.vercel.app
CLIENT_URL=http://localhost:5173
